{
  "manifest_version": 3,
  "name": "eClass 自動播放助手",
  "version": "1.0.0",
  "description": "自動播放 eclass.yuntech.edu.tw 課程影片，支援 eClass 原生播放器與 YouTube 嵌入影片。",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://eclass.yuntech.edu.tw/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "eClass 自動播放助手"
  },
  "content_scripts": [
    {
      "matches": ["*://eclass.yuntech.edu.tw/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
